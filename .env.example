# ── LLM ──────────────────────────────────────────────────────────────────────
# Primary: DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_key_here
# deepseek-chat = DeepSeek-V3 (fast, cheap) | deepseek-reasoner = R1 (stronger reasoning)
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
# Fallbacks (optional)
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# ── Vector DB ─────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=comar_regulations

# ── Graph DB ──────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=comar_password

# ── Embeddings ────────────────────────────────────────────────────────────────
# Options: cpu | cuda | mps
BGE_M3_DEVICE=cpu

# ── Data ──────────────────────────────────────────────────────────────────────
DATA_DIR=./data/xml_cache
